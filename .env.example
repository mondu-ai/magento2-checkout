# Mondu Sandbox API
API_URL=https://api.demo.mondu.ai/api/v1
API_TOKEN=

# Magento Instance
MAGENTO_URL=https://magento.stage.mondu.ai/
MAGENTO_PRODUCT_URL=https://magento.stage.mondu.ai/some-simple-product.html
MAGENTO_BACKEND_URL=https://magento.stage.mondu.ai/admin
MAGENTO_BACKEND_USERNAME=demo
MAGENTO_BACKEND_PASSWORD=demo123

# Webhook signing secret (from Admin → Stores → Config → Mondu → Sandbox Webhook Secret)
WEBHOOK_SECRET=

# Test buyer companies (sandbox-specific names that trigger known flows)
# BUYER_COMPANY_AUTHORIZED: company name that Mondu auto-authorizes immediately
# BUYER_COMPANY_PENDING: company name that Mondu puts in pending state
# BUYER_COMPANY_DECLINED: company name that Mondu declines
# Get these values from Mondu sandbox documentation or your Mondu team contact.
BUYER_COMPANY_AUTHORIZED=Mondu GmbH
BUYER_COMPANY_PENDING=Test Pending Company GmbH
BUYER_COMPANY_DECLINED=Test Declined Company GmbH

# Test buyer personal data
BUYER_FIRST_NAME=Jane
BUYER_LAST_NAME=Doe
BUYER_EMAIL=jane.doe@ext.mondu.ai
BUYER_STREET=Strassmannstr. 45
BUYER_ZIP=10122
BUYER_CITY=Berlin
BUYER_COUNTRY=DE
BUYER_PHONE=+493031196513
